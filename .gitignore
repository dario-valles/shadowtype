# SwiftPM build artifacts
.build/
.swiftpm/
Package.resolved

# Xcode
DerivedData/
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/
*.xcuserstate

# Packaged app bundle output (regenerated by scripts/make-app.sh)
dist/

# Build-generated web assets (the source .svg templates ARE committed):
#   • OG card PNGs — generated by web/worker/scripts/gen-og.ts
#   • AppIcon.iconset — generated from logo.svg by iconutil
web/worker/public/assets/og-*.png
web/assets/AppIcon.iconset/

# Per-machine release config (notary profile, base URL, R2 bucket) written by bin/menu.
# release/state.env IS committed (the shared build counter); only the local secrets/paths are ignored.
release/release.config

# Local model files (fetched on demand; never commit ~GB GGUFs)
*.gguf

# Runtime / debug artifacts
*.log
ocr-debug.png

# Local agent/skill tooling (not project source)
.agents/
skills-lock.json

# Node deps (web/ licensing worker + tooling; reinstall with bun/npm)
node_modules/

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon?

# Claude Code runtime artifacts
.claude/scheduled_tasks.lock
